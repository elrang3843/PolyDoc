<Window x:Class="PolyDoc.App.Views.DocumentInfoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:PolyDoc.App.Services"
        Title="{Binding DocInfoTitle, Source={x:Static svc:LocalizedStrings.Instance}}"
        Width="520" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Window.Resources>
        <!-- 라벨 열: 우측 정렬, muted 색상 -->
        <Style x:Key="FieldLabel" TargetType="TextBlock">
            <Setter Property="Foreground"     Value="{DynamicResource OnSurfaceMuted}" />
            <Setter Property="TextAlignment"  Value="Right" />
            <Setter Property="Margin"         Value="0,3,10,3" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <!-- 값 열 -->
        <Style x:Key="FieldValue" TargetType="TextBlock">
            <Setter Property="TextWrapping"   Value="Wrap" />
            <Setter Property="Margin"         Value="0,3,0,3" />
            <Setter Property="VerticalAlignment" Value="Top" />
        </Style>
        <!-- 섹션 헤더 -->
        <Style x:Key="GroupHeader" TargetType="TextBlock">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin"     Value="0,0,0,6" />
        </Style>
    </Window.Resources>

    <StackPanel Margin="24,20,24,20" MinWidth="420">

        <!-- ── 파일 ─────────────────────────────────────── -->
        <TextBlock Style="{StaticResource GroupHeader}"
                   Text="{Binding DocInfoGroupFile, Source={x:Static svc:LocalizedStrings.Instance}}" />
        <Grid Margin="8,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoPath, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding FilePath}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoFormat, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding Format}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoDataSize, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding DataSize}" />
        </Grid>

        <Separator Margin="0,14,0,12" />

        <!-- ── 문서 속성 ──────────────────────────────────── -->
        <TextBlock Style="{StaticResource GroupHeader}"
                   Text="{Binding DocInfoGroupMeta, Source={x:Static svc:LocalizedStrings.Instance}}" />
        <Grid Margin="8,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoDocTitle, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding DocTitle}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoAuthor, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding Author}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoLanguage, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding Language}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoCreated, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding Created}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoModified, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding Modified}" />
        </Grid>

        <Separator Margin="0,14,0,12" />

        <!-- ── 통계 ──────────────────────────────────────── -->
        <TextBlock Style="{StaticResource GroupHeader}"
                   Text="{Binding DocInfoGroupStats, Source={x:Static svc:LocalizedStrings.Instance}}" />
        <Grid Margin="8,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoParas, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding ParagraphCount}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoChars, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding CharCount}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoWords, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding WordCount}" />

            <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoLines, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding LineCount}" />

            <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoSections, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding SectionCount}" />

            <TextBlock Grid.Row="5" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoTables, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="5" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding TableCount}" />

            <TextBlock Grid.Row="6" Grid.Column="0" Style="{StaticResource FieldLabel}"
                       Text="{Binding DocInfoImages, Source={x:Static svc:LocalizedStrings.Instance}}" />
            <TextBlock Grid.Row="6" Grid.Column="1" Style="{StaticResource FieldValue}"
                       Text="{Binding ImageCount}" />
        </Grid>

        <Separator Margin="0,14,0,12" />

        <!-- ── 닫기 버튼 ─────────────────────────────────── -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding FindReplaceClose, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="12,5" IsDefault="True" IsCancel="True" Click="OnClose" />
        </StackPanel>

    </StackPanel>
</Window>
