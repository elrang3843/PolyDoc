<UserControl x:Class="PolyDoc.App.Views.TextBoxOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True"
             Focusable="True"
             PreviewMouseLeftButtonDown="OnRootMouseDown"
             MouseMove="OnRootMouseMove"
             PreviewMouseLeftButtonUp="OnRootMouseUp"
             KeyDown="OnRootKeyDown">
    <Grid>
        <!-- 모양: 사각형 (이번 사이클 한정. Speech/Cloud/Spiky/Lightning 은 다음 사이클) -->
        <Border x:Name="ShapeBorder"
                Background="White"
                BorderBrush="Black"
                BorderThickness="1" />

        <!-- 내부 편집 영역 -->
        <TextBox x:Name="InnerEditor"
                 Background="Transparent"
                 BorderThickness="0"
                 AcceptsReturn="True"
                 AcceptsTab="True"
                 TextWrapping="Wrap"
                 VerticalScrollBarVisibility="Auto"
                 Margin="6"
                 VerticalContentAlignment="Top"
                 HorizontalContentAlignment="Left"
                 SpellCheck.IsEnabled="False"
                 TextChanged="OnInnerTextChanged" />

        <!-- 선택 시에만 표시되는 chrome (점선 외곽 + 4코너 핸들).
             핸들 캔버스는 IsHitTestVisible 가 자식별로 켜져 마우스를 받을 수 있다. -->
        <Rectangle x:Name="SelectionFrame"
                   Stroke="#4A90E2"
                   StrokeThickness="1"
                   StrokeDashArray="3,2"
                   Fill="Transparent"
                   IsHitTestVisible="False"
                   Visibility="Collapsed"
                   Margin="-1" />

        <Canvas x:Name="HandlesCanvas"
                Background="Transparent"
                IsHitTestVisible="True"
                Visibility="Collapsed">
            <Rectangle x:Name="HandleTL" Width="8" Height="8"
                       Fill="White" Stroke="#4A90E2" StrokeThickness="1"
                       Cursor="SizeNWSE" Tag="TL"
                       PreviewMouseLeftButtonDown="OnHandleMouseDown" />
            <Rectangle x:Name="HandleTR" Width="8" Height="8"
                       Fill="White" Stroke="#4A90E2" StrokeThickness="1"
                       Cursor="SizeNESW" Tag="TR"
                       PreviewMouseLeftButtonDown="OnHandleMouseDown" />
            <Rectangle x:Name="HandleBL" Width="8" Height="8"
                       Fill="White" Stroke="#4A90E2" StrokeThickness="1"
                       Cursor="SizeNESW" Tag="BL"
                       PreviewMouseLeftButtonDown="OnHandleMouseDown" />
            <Rectangle x:Name="HandleBR" Width="8" Height="8"
                       Fill="White" Stroke="#4A90E2" StrokeThickness="1"
                       Cursor="SizeNWSE" Tag="BR"
                       PreviewMouseLeftButtonDown="OnHandleMouseDown" />
        </Canvas>
    </Grid>
</UserControl>
