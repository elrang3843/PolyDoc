<Window x:Class="PolyDonky.App.Views.RowPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="행 속성"
        Width="400" SizeToContent="Height"
        MinWidth="350" MinHeight="200"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 높이 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 머리글 -->
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />  <!-- 버튼 -->
        </Grid.RowDefinitions>

        <!-- ── 높이 (mm) ────────────────────────────────────────────────── -->
        <GroupBox Grid.Row="0" Header="높이 (mm, 0=자동)" Padding="8,4,8,8">
            <TextBox x:Name="HeightBox" Height="32" Padding="8" FontSize="12" />
        </GroupBox>

        <!-- ── 머리글 여부 ───────────────────────────────────────────────── -->
        <GroupBox Grid.Row="2" Header="옵션" Padding="8,4,8,8">
            <CheckBox x:Name="IsHeaderCheck" Content="머리글 행" VerticalAlignment="Center" />
        </GroupBox>

        <!-- ── 버튼 ─────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="OkButton" Content="확인(_O)" Width="100" Margin="0,0,5,0" />
            <Button Name="CancelButton" Content="취소(_C)" Width="100" />
        </StackPanel>
    </Grid>
</Window>
