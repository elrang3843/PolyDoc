<Window x:Class="PolyDonky.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:svc="clr-namespace:PolyDonky.App.Services"
        Title="{Binding SettingsTitle, Source={x:Static svc:LocalizedStrings.Instance}}"
        Width="380" SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <StackPanel Margin="20" MinWidth="320">

        <!-- 테마 -->
        <Label Content="{Binding SettingsTheme, Source={x:Static svc:LocalizedStrings.Instance}}"
               FontWeight="SemiBold" Padding="0,0,0,4" />
        <RadioButton x:Name="ThemeLight"
                     Content="{Binding SettingsThemeLight, Source={x:Static svc:LocalizedStrings.Instance}}"
                     GroupName="Theme" Margin="0,2" IsChecked="True" Checked="OnThemeChecked" />
        <RadioButton x:Name="ThemeDark"
                     Content="{Binding SettingsThemeDark, Source={x:Static svc:LocalizedStrings.Instance}}"
                     GroupName="Theme" Margin="0,2" Checked="OnThemeChecked" />
        <RadioButton x:Name="ThemeSoft"
                     Content="{Binding SettingsThemeSoft, Source={x:Static svc:LocalizedStrings.Instance}}"
                     GroupName="Theme" Margin="0,2" Checked="OnThemeChecked" />

        <Separator Margin="0,14,0,10" />

        <!-- 언어 -->
        <Label Content="{Binding SettingsLanguage, Source={x:Static svc:LocalizedStrings.Instance}}"
               FontWeight="SemiBold" Padding="0,0,0,4" />
        <RadioButton x:Name="LangKorean"
                     Content="{Binding SettingsLangKorean, Source={x:Static svc:LocalizedStrings.Instance}}"
                     GroupName="Language" Margin="0,2" IsChecked="True" Checked="OnLanguageChecked" />
        <RadioButton x:Name="LangEnglish"
                     Content="{Binding SettingsLangEnglish, Source={x:Static svc:LocalizedStrings.Instance}}"
                     GroupName="Language" Margin="0,2" Checked="OnLanguageChecked" />

        <Separator Margin="0,14,0,10" />

        <!-- 파일 저장 -->
        <Label Content="{Binding SettingsSave, Source={x:Static svc:LocalizedStrings.Instance}}"
               FontWeight="SemiBold" Padding="0,0,0,4" />
        <CheckBox x:Name="OverwriteProtectionCheck"
                  Content="{Binding SettingsOverwriteProtect, Source={x:Static svc:LocalizedStrings.Instance}}"
                  Margin="0,2"
                  Checked="OnOverwriteProtectionChanged"
                  Unchecked="OnOverwriteProtectionChanged" />

        <Separator Margin="0,14,0,10" />

        <!-- LibreOffice -->
        <Label Content="{Binding SettingsLibreOffice, Source={x:Static svc:LocalizedStrings.Instance}}"
               FontWeight="SemiBold" Padding="0,0,0,4" />
        <StackPanel Orientation="Horizontal" Margin="0,4">
            <TextBox x:Name="LibreOfficePathBox"
                     IsReadOnly="True"
                     VerticalAlignment="Center"
                     Margin="0,0,8,0"
                     Foreground="{DynamicResource OnSurfaceVariant}" />
            <Button Content="{Binding SettingsLibreOfficeDetect, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="12,5" Click="OnDetectLibreOffice"
                    Foreground="{DynamicResource Primary}"
                    Background="Transparent"
                    BorderThickness="0" />
        </StackPanel>
        <TextBlock Foreground="{DynamicResource OnSurfaceVariant}"
                   Margin="0,6,0,4"
                   Text="{Binding SettingsLibreOfficeHelp, Source={x:Static svc:LocalizedStrings.Instance}}"
                   TextWrapping="Wrap"
                   FontSize="11" />
        <TextBlock Margin="0,4,0,0">
            <Hyperlink NavigateUri="https://www.libreoffice.org/download/"
                       RequestNavigate="OnLibreOfficeDownloadClick"
                       Foreground="{DynamicResource Primary}">
                <Run Text="{Binding SettingsLibreOfficeDownload, Source={x:Static svc:LocalizedStrings.Instance}, Mode=OneWay}" />
            </Hyperlink>
        </TextBlock>

        <Separator Margin="0,14,0,12" />

        <!-- 닫기 버튼 -->
        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{Binding FindReplaceClose, Source={x:Static svc:LocalizedStrings.Instance}}"
                    Padding="12,5" IsCancel="True" Click="OnClose" />
        </StackPanel>
    </StackPanel>
</Window>
