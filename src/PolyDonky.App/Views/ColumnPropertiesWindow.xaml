<Window x:Class="PolyDonky.App.Views.ColumnPropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="열 속성"
        Width="400" SizeToContent="Height"
        MinWidth="350" MinHeight="150"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 너비 -->
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />  <!-- 버튼 -->
        </Grid.RowDefinitions>

        <!-- ── 너비 (mm) ─────────────────────────────────────────────────── -->
        <GroupBox Grid.Row="0" Header="너비 (mm, 0=자동)" Padding="8,4,8,8">
            <TextBox x:Name="WidthBox" Height="32" Padding="8" FontSize="12" />
        </GroupBox>

        <!-- ── 버튼 ─────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Name="OkButton" Content="확인(_O)" Width="100" Margin="0,0,5,0" />
            <Button Name="CancelButton" Content="취소(_C)" Width="100" />
        </StackPanel>
    </Grid>
</Window>
