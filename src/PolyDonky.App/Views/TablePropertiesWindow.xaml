<Window x:Class="PolyDonky.App.Views.TablePropertiesWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:PolyDonky.App.Controls"
        Title="표 속성"
        Width="500" SizeToContent="Height"
        MinWidth="460"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        ShowInTaskbar="False"
        FontFamily="{DynamicResource UiFont}"
        Background="{DynamicResource Surface}"
        Foreground="{DynamicResource OnSurface}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- 배치 모드 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 오버레이 위치 (조건부) -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 표 정렬 (Block 모드 전용) -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 표 크기 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 배경색 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 기본 셀 안여백 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 바깥 여백 -->
            <RowDefinition Height="10" />
            <RowDefinition Height="Auto" />  <!-- 표 외곽선 -->
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />  <!-- 버튼 -->
        </Grid.RowDefinitions>

        <!-- ── 배치 모드 ───────────────────────────────────────────────── -->
        <GroupBox Grid.Row="0" Header="배치 방식" Padding="8,4,8,8">
            <WrapPanel>
                <RadioButton x:Name="WrapBlockRadio"
                             Content="본문 흐름(_B)"
                             IsChecked="True"
                             Margin="0,0,12,0"
                             Click="OnWrapModeChanged" />
                <RadioButton x:Name="WrapFrontRadio"
                             Content="텍스트 위(_F)"
                             Margin="0,0,12,0"
                             Click="OnWrapModeChanged" />
                <RadioButton x:Name="WrapBehindRadio"
                             Content="텍스트 아래(_D)"
                             Margin="0,0,12,0"
                             Click="OnWrapModeChanged" />
                <RadioButton x:Name="WrapFixedRadio"
                             Content="위치 고정(_X)"
                             Click="OnWrapModeChanged" />
            </WrapPanel>
        </GroupBox>

        <!-- ── 오버레이 위치 — InFrontOfText/BehindText/Fixed 모드 전용 ── -->
        <GroupBox x:Name="GrpOverlayPos" Grid.Row="2" Header="오버레이 위치 (페이지 좌상단 기준)"
                  Padding="8,4,8,8" Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Row="0" Grid.Column="0" Text="X (mm):" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="OverlayXBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="Y (mm):" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="0" Grid.Column="4" x:Name="OverlayYBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="고정 페이지:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="AnchorPageBox"
                           Text="1" TextAlignment="Right" VerticalContentAlignment="Center"
                           ToolTip="1부터 시작하는 페이지 번호. 해당 페이지 좌상단 기준으로 X/Y 좌표를 배치." />
            </Grid>
        </GroupBox>

        <!-- ── 표 정렬 (Block 모드 전용) ─────────────────────────────────── -->
        <GroupBox x:Name="GrpHAlign" Grid.Row="4" Header="표 정렬" Padding="8,4,8,8">
            <StackPanel Orientation="Horizontal">
                <RadioButton x:Name="AlignLeftRadio"   Content="왼쪽(_L)"   IsChecked="True" Margin="0,0,12,0" />
                <RadioButton x:Name="AlignCenterRadio" Content="가운데(_C)"                   Margin="0,0,12,0" />
                <RadioButton x:Name="AlignRightRadio"  Content="오른쪽(_R)"                   />
            </StackPanel>
        </GroupBox>

        <!-- ── 표 크기 ───────────────────────────────────────────────────── -->
        <GroupBox Grid.Row="6" Header="표 크기 (mm, 0 = 자동)" Padding="8,4,8,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                    <ColumnDefinition Width="20" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="70" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="너비:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Column="1" x:Name="TableWidthBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center"
                           ToolTip="0이면 페이지 본문 너비(100%)로 자동 설정" />
                <TextBlock Grid.Column="3" Text="높이:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Column="4" x:Name="TableHeightBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center"
                           ToolTip="0이면 행 높이 합계로 자동 계산" />
            </Grid>
        </GroupBox>

        <!-- ── 표 배경색 ─────────────────────────────────────────────────── -->
        <GroupBox Grid.Row="8" Header="표 배경색" Padding="8,4,8,8">
            <ctrl:ColorPickerBox x:Name="BgColorPicker" AllowEmpty="True" />
        </GroupBox>

        <!-- ── 기본 셀 안여백 (mm) ─────────────────────────────────────── -->
        <GroupBox Grid.Row="10" Header="기본 셀 안여백 (mm) — 개별 셀 설정이 없을 때 사용" Padding="8,4,8,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="위:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="CellPadTopBox"
                           Text="1.0" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="아래:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="0" Grid.Column="4" x:Name="CellPadBottomBox"
                           Text="1.0" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="왼쪽:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="CellPadLeftBox"
                           Text="1.5" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="2" Grid.Column="3" Text="오른쪽:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="2" Grid.Column="4" x:Name="CellPadRightBox"
                           Text="1.5" TextAlignment="Right" VerticalContentAlignment="Center" />
            </Grid>
        </GroupBox>

        <!-- ── 바깥 여백 (mm) ─────────────────────────────────────────── -->
        <GroupBox Grid.Row="12" Header="바깥 여백 (mm)" Padding="8,4,8,8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="6" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="56" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="56" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="위:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="0" Grid.Column="1" x:Name="OuterMarginTopBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="0" Grid.Column="3" Text="아래:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="0" Grid.Column="4" x:Name="OuterMarginBottomBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="2" Grid.Column="0" Text="왼쪽:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="2" Grid.Column="1" x:Name="OuterMarginLeftBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />
                <TextBlock Grid.Row="2" Grid.Column="3" Text="오른쪽:" VerticalAlignment="Center" Margin="0,0,4,0" />
                <TextBox   Grid.Row="2" Grid.Column="4" x:Name="OuterMarginRightBox"
                           Text="0" TextAlignment="Right" VerticalContentAlignment="Center" />
            </Grid>
        </GroupBox>

        <!-- ── 표 외곽선 — 공통 + 면별 ───────────────────────────────────── -->
        <GroupBox Grid.Row="14" Header="표 외곽선" Padding="8,4,8,8">
            <StackPanel>
                <!-- 공통값 — 면별 미지정 시 적용 -->
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="6" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="64" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="공통 두께:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <TextBox   Grid.Row="0" Grid.Column="1" x:Name="BorderThicknessBox"
                               Text="0" TextAlignment="Right" VerticalContentAlignment="Center"
                               ToolTip="0이면 외곽선 없음 — 면별 설정이 없을 때 사용" />
                    <TextBlock Grid.Row="0" Grid.Column="2" Text=" pt" VerticalAlignment="Center"
                               Foreground="{DynamicResource OnSurfaceMuted}" />
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="공통 색상:" VerticalAlignment="Center" Margin="0,0,6,0" />
                    <ctrl:ColorPickerBox x:Name="BorderColorPicker"
                                         Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2"
                                         AllowEmpty="True" />
                </Grid>

                <!-- 면별 설정 토글 -->
                <ToggleButton x:Name="PerSideToggle" Margin="0,8,0,0"
                              HorizontalAlignment="Left"
                              Click="OnPerSideToggleClick"
                              Content="면별 설정 펼치기 ▾" />

                <!-- 면별 편집 — 6면 (외곽 4 + 안쪽 가로/세로) -->
                <StackPanel x:Name="PerSidePanel" Visibility="Collapsed" Margin="0,8,0,0">
                    <ctrl:BorderSideEditor x:Name="SideTop"    Margin="0,2" />
                    <ctrl:BorderSideEditor x:Name="SideBottom" Margin="0,2" />
                    <ctrl:BorderSideEditor x:Name="SideLeft"   Margin="0,2" />
                    <ctrl:BorderSideEditor x:Name="SideRight"  Margin="0,2" />
                    <Separator Margin="0,4" />
                    <ctrl:BorderSideEditor x:Name="SideInnerH" Margin="0,2" />
                    <ctrl:BorderSideEditor x:Name="SideInnerV" Margin="0,2" />
                </StackPanel>

                <!-- 테두리 병합 옵션 -->
                <CheckBox x:Name="BorderCollapseCheck"
                          Content="인접 셀 테두리 병합 — 공유 모서리를 단일 선으로 표시(_C)"
                          IsChecked="True"
                          Margin="0,8,0,0"
                          ToolTip="활성화: 인접 셀 사이 단일 선, 비활성화: 셀별 테두리 (doubled 라인 발생)" />
            </StackPanel>
        </GroupBox>

        <!-- ── 페이지 분할 옵션 ───────────────────────────────────────────── -->
        <GroupBox Grid.Row="15" Header="페이지 분할" Padding="8,4,8,8" Margin="0,10,0,0">
            <StackPanel>
                <CheckBox x:Name="RepeatHeaderRowsCheck"
                          Content="헤더 행 반복 — 페이지를 넘을 때 헤더 행을 각 조각 상단에 표시(_R)"
                          IsChecked="True"
                          Margin="0,0,0,6" />
            </StackPanel>
        </GroupBox>

        <!-- ── 버튼 ─────────────────────────────────────────────────────── -->
        <StackPanel Grid.Row="16" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="확인(_O)"
                    Width="88" Height="30"
                    IsDefault="True"
                    Click="OnOkClick"
                    Margin="0,0,8,0" />
            <Button Content="취소"
                    Width="88" Height="30"
                    IsCancel="True"
                    Click="OnCancelClick" />
        </StackPanel>
    </Grid>
</Window>
